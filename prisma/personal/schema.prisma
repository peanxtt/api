generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/prisma/personal"
}

datasource db {
  provider = "postgresql"
}

model checklists {
  id                   String   @id
  userId               String
  title                String
  description          String?
  clientId             String?
  items                Json
  status               String   @default("not_started")
  completionPercentage Float    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime
  clients              clients? @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([status])
  @@index([userId])
}

model clients {
  id         String       @id
  userId     String
  name       String
  email      String?
  company    String?
  phone      String?
  address    String?
  notes      String?
  active     Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  checklists checklists[]
  invoices   invoices[]
  projects   projects[]
  receipts   receipts[]
  tasks      tasks[]

  @@index([active])
  @@index([userId])
}

model invoices {
  id                String   @id
  userId            String
  clientId          String?
  clientName        String?
  clientCompanyName String
  clientEmail       String?
  clientPhone       String?
  clientAddress     String?
  project           String?
  invoiceNumber     String?
  issueDate         String?
  dueDate           String?
  currency          String   @default("MYR")
  mode              String   @default("invoice")
  status            String   @default("draft")
  taxRate           Float    @default(0)
  notes             String?
  total             Float    @default(0)
  lines             Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  clients           clients? @relation(fields: [clientId], references: [id])
  tasks             tasks[]

  @@index([clientId])
  @@index([mode])
  @@index([status])
  @@index([userId])
}

model projects {
  id                   String    @id
  userId               String
  title                String
  description          String?
  goal                 String?
  type                 String    @default("project")
  startDate            DateTime?
  deadline             DateTime?
  status               String    @default("active")
  archived             Boolean   @default(false)
  color                String?
  icon                 String?
  position             Int       @default(0)
  completionPercentage Float     @default(0)
  taskCount            Int       @default(0)
  completedTaskCount   Int       @default(0)
  clientId             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime
  clients              clients?  @relation(fields: [clientId], references: [id])
  tasks                tasks[]

  @@index([archived])
  @@index([clientId])
  @@index([status])
  @@index([type])
  @@index([userId])
}

model receipts {
  id                String   @id
  userId            String
  clientId          String?
  clientName        String?
  clientCompanyName String
  clientEmail       String?
  clientPhone       String?
  clientAddress     String?
  project           String?
  receiptNumber     String?
  currency          String   @default("MYR")
  mode              String   @default("receipt")
  status            String   @default("done")
  taxRate           Float    @default(0)
  notes             String?
  total             Float    @default(0)
  lines             Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  invoiceNumber     String?
  clients           clients? @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([userId])
}

model settings {
  id                        String   @id
  userId                    String   @unique
  companyName               String
  addressLine1              String?
  addressLine2              String?
  addressLine3              String?
  addressLine4              String?
  email                     String?
  phone                     String?
  sstRegistrationNumber     String?
  companyRegistrationNumber String?
  bankName                  String?
  bankAccountName           String?
  bankAccountNumber         String?
  defaultCurrency           String   @default("MYR")
  defaultTaxRate            Float    @default(0)
  defaultPaymentTerms       String?
  pomodoroWorkDuration      Int      @default(25)
  pomodoroBreakDuration     Int      @default(5)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime
}

model task_blockers {
  id                                       String   @id
  blockedTaskId                            String
  blockerTaskId                            String
  createdAt                                DateTime @default(now())
  tasks_task_blockers_blockedTaskIdTotasks tasks    @relation("task_blockers_blockedTaskIdTotasks", fields: [blockedTaskId], references: [id], onDelete: Cascade)
  tasks_task_blockers_blockerTaskIdTotasks tasks    @relation("task_blockers_blockerTaskIdTotasks", fields: [blockerTaskId], references: [id], onDelete: Cascade)

  @@unique([blockedTaskId, blockerTaskId])
  @@index([blockedTaskId])
  @@index([blockerTaskId])
}

model tasks {
  id                                               String          @id
  userId                                           String
  title                                            String
  description                                      String?
  status                                           String          @default("todo")
  priority                                         String          @default("medium")
  parentTaskId                                     String?
  clientId                                         String?
  invoiceId                                        String?
  dueDate                                          String?
  estimatedHours                                   Float?
  actualHours                                      Float?
  position                                         Int             @default(0)
  archived                                         Boolean         @default(false)
  tags                                             String[]
  createdAt                                        DateTime        @default(now())
  updatedAt                                        DateTime
  projectId                                        String?
  task_blockers_task_blockers_blockedTaskIdTotasks task_blockers[] @relation("task_blockers_blockedTaskIdTotasks")
  task_blockers_task_blockers_blockerTaskIdTotasks task_blockers[] @relation("task_blockers_blockerTaskIdTotasks")
  clients                                          clients?        @relation(fields: [clientId], references: [id])
  invoices                                         invoices?       @relation(fields: [invoiceId], references: [id])
  tasks                                            tasks?          @relation("tasksTotasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  other_tasks                                      tasks[]         @relation("tasksTotasks")
  projects                                         projects?       @relation(fields: [projectId], references: [id])

  @@index([archived])
  @@index([clientId])
  @@index([invoiceId])
  @@index([parentTaskId])
  @@index([priority])
  @@index([projectId])
  @@index([status])
  @@index([userId])
}
