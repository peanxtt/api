generator client {
  provider = "prisma-client-js"
  output   = "../../src/generated/prisma/coffee"
}

datasource db {
  provider = "postgresql"
}

model CoffeeEntry {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  body      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
